EXIT int@0

LABEL $$EXIT25
EXIT int@25

LABEL $$EXIT26
EXIT int@26

# ======================= NEW INSTRUCTION =======================
#LABEL              | ____            | main$0          | ____

LABEL $$main
PUSHFRAME
DEFVAR LF@a$0

# ======================= NEW INSTRUCTION =======================
#FUNC_BEGIN         | ____            | main$0          | ____

# ======================= NEW INSTRUCTION =======================
#DECLARE            | a               | ____            | ____
MOVE LF@a$0 nil@nil

