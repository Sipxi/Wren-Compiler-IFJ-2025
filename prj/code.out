.IFJcode25
DEFVAR GF@$tmp
DEFVAR GF@$tmp_2
DEFVAR GF@$tmp_type_1
DEFVAR GF@$tmp_type_2   
DEFVAR GF@$tmp_op_1
DEFVAR GF@$tmp_op_2
DEFVAR GF@$ret_ifj_fun
DEFVAR GF@$getter_1
DEFVAR GF@$getter_2
DEFVAR GF@__stored$0
MOVE GF@__stored$0 nil@nil
DEFVAR GF@__a$0
MOVE GF@__a$0 nil@nil
CREATEFRAME
CALL $$main
EXIT int@0

LABEL $$EXIT25
EXIT int@25

LABEL $$EXIT26
EXIT int@26

# ======================= NEW INSTRUCTION =======================
#LABEL              | ____            | main$0          | ____

LABEL $$main
PUSHFRAME
DEFVAR LF@$t$0
DEFVAR LF@$t$1

# ======================= NEW INSTRUCTION =======================
#FUNC_BEGIN         | ____            | main$0          | ____

# ======================= NEW INSTRUCTION =======================
#ASSIGN             | value$setter    | 42              | ____
CREATEFRAME
DEFVAR TF@v$0
MOVE TF@v$0 int@42
CALL $value$setter

# ======================= NEW INSTRUCTION =======================
#CALL               | ____            | fun$2           | ____
CREATEFRAME
DEFVAR TF@ret
MOVE TF@ret nil@nil
DEFVAR TF@a$0
PUSHFRAME
CREATEFRAME
DEFVAR TF@ret
MOVE TF@ret nil@nil
CALL $value$getter
MOVE LF@a$0 TF@ret
POPFRAME
DEFVAR TF@b$0
PUSHFRAME
CREATEFRAME
DEFVAR TF@ret
MOVE TF@ret nil@nil
CALL $value$getter
MOVE LF@b$0 TF@ret
POPFRAME
CALL $fun$2

# ======================= NEW INSTRUCTION =======================
#ASSIGN             | __a             | fun$2           | ____
MOVE GF@__a$0 TF@ret

# ======================= NEW INSTRUCTION =======================
#FUNC_END           | ____            | main$0          | ____
POPFRAME
RETURN

# ======================= NEW INSTRUCTION =======================
#LABEL              | ____            | value$getter    | ____

LABEL $value$getter
PUSHFRAME

# ======================= NEW INSTRUCTION =======================
#FUNC_BEGIN         | ____            | value$getter    | ____

# ======================= NEW INSTRUCTION =======================
#JUMP_IF_FALSE      | ____            | __stored        | L_ELSE_0
JUMPIFEQ $L_ELSE_0 GF@__stored$0 nil@nil
TYPE GF@$tmp_type_1 GF@__stored$0
JUMPIFNEQ $SKIP_BOOL_CHECK_2 GF@$tmp_type_1 string@bool
JUMPIFEQ $L_ELSE_0 GF@__stored$0 bool@false

LABEL $SKIP_BOOL_CHECK_2

# ======================= NEW INSTRUCTION =======================
#RETURN             | __stored        | ____            | ____
MOVE LF@ret GF@__stored$0
POPFRAME
RETURN

# ======================= NEW INSTRUCTION =======================
#LABEL              | ____            | L_ELSE_0        | ____

LABEL $L_ELSE_0

# ======================= NEW INSTRUCTION =======================
#RETURN             | 0               | ____            | ____
MOVE LF@ret int@0
POPFRAME
RETURN

# ======================= NEW INSTRUCTION =======================
#LABEL              | ____            | L_ENDIF_1       | ____

LABEL $L_ENDIF_1

# ======================= NEW INSTRUCTION =======================
#FUNC_END           | ____            | value$getter    | ____
POPFRAME
RETURN

# ======================= NEW INSTRUCTION =======================
#LABEL              | ____            | value$setter    | ____

LABEL $value$setter
PUSHFRAME

# ======================= NEW INSTRUCTION =======================
#FUNC_BEGIN         | ____            | value$setter    | ____

# ======================= NEW INSTRUCTION =======================
#PARAM              | v               | ____            | ____

# ======================= NEW INSTRUCTION =======================
#ASSIGN             | __stored        | v               | ____
MOVE GF@__stored$0 LF@v$0

# ======================= NEW INSTRUCTION =======================
#FUNC_END           | ____            | value$setter    | ____
POPFRAME
RETURN

# ======================= NEW INSTRUCTION =======================
#LABEL              | ____            | fun$2           | ____

LABEL $fun$2
PUSHFRAME

# ======================= NEW INSTRUCTION =======================
#FUNC_BEGIN         | ____            | fun$2           | ____

# ======================= NEW INSTRUCTION =======================
#PARAM              | a               | ____            | ____

# ======================= NEW INSTRUCTION =======================
#PARAM              | b               | ____            | ____

# ======================= NEW INSTRUCTION =======================
#CALL               | ____            | Ifj.write$1     | ____
MOVE GF@$ret_ifj_fun nil@nil
MOVE GF@$tmp_op_1 LF@a$0
TYPE GF@$tmp_type_1 GF@$tmp_op_1
JUMPIFNEQ $WRITE_3 GF@$tmp_type_1 string@float
ISINT GF@$tmp GF@$tmp_op_1
JUMPIFEQ $WRITE_3 GF@$tmp bool@false
FLOAT2INT GF@$tmp_op_1 GF@$tmp_op_1

LABEL $WRITE_3
WRITE GF@$tmp_op_1

# ======================= NEW INSTRUCTION =======================
#ASSIGN             | a               | Ifj.write$1     | ____
MOVE LF@a$0 GF@$ret_ifj_fun

# ======================= NEW INSTRUCTION =======================
#CALL               | ____            | Ifj.write$1     | ____
MOVE GF@$ret_ifj_fun nil@nil
MOVE GF@$tmp_op_1 LF@b$0
TYPE GF@$tmp_type_1 GF@$tmp_op_1
JUMPIFNEQ $WRITE_4 GF@$tmp_type_1 string@float
ISINT GF@$tmp GF@$tmp_op_1
JUMPIFEQ $WRITE_4 GF@$tmp bool@false
FLOAT2INT GF@$tmp_op_1 GF@$tmp_op_1

LABEL $WRITE_4
WRITE GF@$tmp_op_1

# ======================= NEW INSTRUCTION =======================
#ASSIGN             | b               | Ifj.write$1     | ____
MOVE LF@b$0 GF@$ret_ifj_fun

# ======================= NEW INSTRUCTION =======================
#FUNC_END           | ____            | fun$2           | ____
POPFRAME
