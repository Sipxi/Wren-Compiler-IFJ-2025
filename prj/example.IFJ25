// Correct: Getter and setter usage
import "ifj25" for Ifj
class Program {
    
    static main() {
        //var a
        //var b
        //var c
        __res = str + str
        __tr = Ifj.write(__res)
    }
    static str {
        return "123"
    }
    static int {
        return 123
    }
    static float {
        return 1.23
    }
    static nil {
        return null
    }
}
