{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Main Program (make run)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/prj/ifj_compiler",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/prj",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build-main",
            "miDebuggerPath": "/usr/bin/gdb",
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": "Debug Test Playground (make test-pg)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/prj/test_playground",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/prj",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build-test",
            "miDebuggerPath": "/usr/bin/gdb",
            "internalConsoleOptions": "openOnSessionStart"
        }
    ]
}